  "staking": {
    "staking_tokens": [
      {
        "denom": "ulwp"
      }
    ]
  },
  "codebase": {
    "git_repo": "https://github.com/LumiWave/lumiwave-protocol",
    "genesis": {
      "genesis_url": "https://lwp-mainnet-rpc.lumiwavelab.com/genesis"
    },
    "recommended_version": "v0.0.11",
