    "rest": [
      {
        "address": "https://rest.mainnet.rubin.trade",
        "provider": "Rubin"
      }
    ],
    "grpc": [
      {
        "address": "grpc.mainnet.rubin.trade:443",
        "provider": "Rubin"
      }
    ]
