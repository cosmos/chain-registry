{
  "$schema": "../chain.schema.json",
  "chain_name": "omnis",
  "chain_id": "omnis-1",
  "pretty_name": "Omnis Chain",
  "status": "live",
  "network_type": "mainnet",
  "website": "https://omnischain.org",
  "bech32_prefix": "omnis",
  "daemon_name": "omnischaind",
  "node_home": "$HOME/.omnis",
  "key_algos": ["secp256k1"],
  "slip44": 118,
  "fees": {
    "fee_tokens": [
      {
        "denom": "uomn",
        "fixed_min_gas_price": 0.025,
        "low_gas_price": 0.025,
        "average_gas_price": 0.05,
        "high_gas_price": 0.1
      }
    ]
  },
  "staking": {
    "staking_tokens": [{ "denom": "uomn" }]
  },
  "codebase": {
    "recommended_version": "v1.0.0",
    "compatible_versions": ["v1.0.0"],
    "cosmos_sdk_version": "0.50",
    "cosmwasm_enabled": true,
    "cosmwasm_version": "0.53"
  },
  "peers": {
    "seeds": [],
    "persistent_peers": [
      {
        "id": "039b9dfd5e65d91e89e6794ee3bd510035c1da38",
        "address": "31.220.109.62:26656",
        "provider": "Omnis Chain Official"
      }
    ]
  },
  "apis": {
    "rpc": [
      {
        "address": "https://omnischain.org/rpc",
        "provider": "Omnis Chain Official"
      }
    ],
    "rest": [
      {
        "address": "https://omnischain.org/lcd",
        "provider": "Omnis Chain Official"
      }
    ],
    "grpc": [
      {
        "address": "grpc.omnischain.org:443",
        "provider": "Omnis Chain Official"
      }
    ]
  },
  "explorers": [
    {
      "kind": "omnis-explorer",
      "url": "https://omnischain.org/explorer",
      "tx_page": "https://omnischain.org/explorer/tx/${txHash}",
      "account_page": "https://omnischain.org/explorer/address/${accountAddress}"
    }
  ],
  "logo_URIs": {
    "png": "https://raw.githubusercontent.com/cosmos/chain-registry/master/omnis/images/icon.png",
    "svg": "https://raw.githubusercontent.com/cosmos/chain-registry/master/omnis/images/icon.svg"
  },
  "description": "Omnis Chain is a Layer 1 blockchain built on Cosmos SDK with CosmWasm smart contracts support for token creation (OMS20) and DEX functionality."
}
